<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <NoWarn>$(NoWarn);xUnit1051;CA2000;CA1849;CA1508;xUnit1012</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="coverlet.collector">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="Microsoft.Extensions.TimeProvider.Testing" />
    <PackageReference Include="FluentAssertions" />
    <PackageReference Include="Moq" />
    <PackageReference Include="xunit.runner.visualstudio">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="xunit.v3" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Xunit" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\samples\Sentinel.Sample.MinimalApi\Sentinel.Sample.MinimalApi.csproj" />
    <ProjectReference Include="..\..\src\Sentinel.Application\Sentinel.Application.csproj" />
    <ProjectReference Include="..\..\src\Sentinel.Infrastructure\Sentinel.Infrastructure.csproj" />
    <ProjectReference Include="..\..\src\Sentinel.AspNetCore\Sentinel.AspNetCore.csproj" />
    <ProjectReference Include="..\..\src\Sentinel.SdJwt\Sentinel.SdJwt.csproj" />
    <ProjectReference Include="..\..\src\Sentinel.Rar\Sentinel.Rar.csproj" />
    <ProjectReference Include="..\..\src\Sentinel.Redis\Sentinel.Redis.csproj" />
    <ProjectReference Include="..\..\src\Sentinel.EntityFrameworkCore\Sentinel.EntityFrameworkCore.csproj" />
    <ProjectReference Include="..\..\src\Sentinel.Session\Sentinel.Session.csproj" />
    <ProjectReference Include="..\..\src\Sentinel.SSF\Sentinel.SSF.csproj" />
    <ProjectReference Include="..\..\src\Sentinel.Keycloak\Sentinel.Keycloak.csproj" />
  </ItemGroup>

</Project>
