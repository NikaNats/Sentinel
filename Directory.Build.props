<Project>
  <PropertyGroup>
    <TargetFramework>net11.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- Security Enforcement -->
    <AnalysisMode>All</AnalysisMode>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>

    <NoWarn>
      $(NoWarn);
      CS1591; <!-- Missing XML comments -->
      CA1031; <!-- Catching generic Exception - Intentional for fail-closed security middleware (RFC 9449 compliance) -->
      CA1032; <!-- Exception constructors -->
      CA1034; <!-- Do not nest type (acceptable for Request/Response DTOs in Controllers) -->
      CA1054; <!-- URI parameters - Framework-specific; acceptable for routing/OpenAPI contexts -->
      CA1062; <!-- Validate arguments (redundant with Nullable enable) -->
      CA1515; <!-- Because an application's API isn't typically referenced from outside the assembly (Program.cs) -->
      CA1819; <!-- Properties should not return arrays (acceptable for API serialization) -->
      CA1848; <!-- LoggerMessage source generator - Performance optimization; deferred to "Polish Phase" -->
      CA1873; <!-- Equality operator performance - Micro-optimization; defer to after security implementation stabilizes -->
      CA5398; <!-- Avoid hardcoding SslProtocols (acceptable for explicit TLS 1.3 enforcement in mTLS scenarios) -->
      CA5404; <!-- Custom DPoP/iat validation overrides standard lifetime checks -->
      CA1850; <!-- SHA256.HashData optimization -->
      IDE0005; <!-- Unused usings (handles Roslyn CI bug) -->
    </NoWarn>
  </PropertyGroup>

  <!-- Test Project Customization -->
  <PropertyGroup Condition="'$(IsTestProject)' == 'true' Or '$(IsTestingPlatformApplication)' == 'true'">
    <NoWarn>
      $(NoWarn);
      CA1707; <!-- Remove underscores from test method names (standard test naming convention) -->
      CA1711; <!-- Rename type names ending with 'Collection' (standard xUnit Fixture naming) -->
      CA1812; <!-- Internal class never instantiated (acceptable for test helper classes and mocks) -->
      CA2000; <!-- Dispose objects created in tests (acceptable for HttpClient/message handlers in test fixtures) -->
      CA2213; <!-- IDisposable fields in test fixtures (acceptable for Testcontainers lifecycle management) -->
      CA2234; <!-- Modify to call Uri overload (acceptable for test endpoint strings) -->
    </NoWarn>
  </PropertyGroup>
</Project>
