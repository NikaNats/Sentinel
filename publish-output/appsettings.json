  },
  "Keycloak": {
    "Authority": "https://localhost:8443/realms/sentinel",
    "Audience": "sentinel-api",
    "SsoSessionMaxLifespanSeconds": 28800
  },
  "Cryptography": {
    "MasterKey": "__SET_IN_KEY_VAULT_OR_USER_SECRETS__"
  },
  "FeatureFlags": {
    "Auth": {
      "DpopFlow": true
    }
  },
  "Logging": {
    "LogLevel": {
