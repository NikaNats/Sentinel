{
  "ConnectionStrings": {
    "Redis": "localhost:6379"
  },
  "AcrRanking": {
    "Rankings": {
      "acr1": 1,
      "acr2": 2,
      "acr3": 3
    }
  },
  "Sentinel": {
    "SecurityLevels": {
      "RequiredAcr": "acr2",
      "ElevatedClearanceLevels": [ "top-secret", "classified", "secret" ]
    },
    "Keycloak": {
      "Authority": "http://localhost:8080/realms/sentinel",
      "Audience": "sentinel-api",
      "RequireHttpsMetadata": false
    }
  },
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/sentinel",
    "Audience": "sentinel-api",
    "RequireHttpsMetadata": false
  },
  "Cryptography": {
    "ActiveKeyId": "default",
    "KeyRing": {
      "default": "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
    }
  },
  "FeatureFlags": {
    "Auth": {
      "DpopFlow": true
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.AspNetCore.Routing": "Debug",
      "Microsoft.AspNetCore.Hosting": "Information"
    }
  },
  "Mtls": {
    "AllowDirectConnection": true,
    "CertificateHeaders": [
      "X-Client-Cert",
      "X-SSL-Client-Cert",
      "X-ARR-ClientCert",
      "X-Amzn-Mtls-Client-Cert"
    ],
    "TrustedProxies": [
      "127.0.0.1/32",
      "::1/128",
      "10.0.0.0/8"
    ]
  }
}
