{
  "ConnectionStrings": {
    "Redis": "localhost:6379"
  },
  "AcrRanking": {
    "Rankings": {
      "acr1": 1,
      "acr2": 2,
      "acr3": 3
    }
  },
  "DPoP": {
    "AllowedAlgorithms": [ "PS256", "ES256" ],
    "ProofLifetimeSeconds": 60,
    "AllowedClockSkewSeconds": 10
  },
  "Sentinel": {
    "Security": {
      "Captcha": {
        "Enabled": true,
        "SecretKey": "0x4AAAAAAABB-MOCK-SECRET",
        "VerificationUrl": "https://challenges.cloudflare.com/turnstile/v0/siteverify",
        "TimeoutSeconds": 5
      },
      "PasswordPolicy": {
        "MinimumLength": 12,
        "MaximumLength": 128,
        "RequireUppercase": true,
        "RequireLowercase": true,
        "RequireDigit": true,
        "RequireNonAlphanumeric": true,
        "MinimumEntropyBits": 50.0,
        "CustomBlacklist": []
      }
    },
    "SecurityLevels": {
      "RequiredAcr": "acr2",
      "ElevatedClearanceLevels": [ "top-secret", "classified", "secret" ]
    },
    "Keycloak": {
      "Authority": "https://localhost:8443/realms/sentinel",
      "Audience": "sentinel-api",
      "RequireHttpsMetadata": true
    },
    "Mtls": {
      "AllowDirectConnection": true,
      "CertificateHeaders": [
        "X-Client-Cert",
        "X-SSL-Client-Cert",
        "X-ARR-ClientCert",
        "X-Amzn-Mtls-Client-Cert"
      ],
      "TrustedProxies": [
        "10.244.0.0/16",
        "172.16.0.0/12",
        "127.0.0.1/32",
        "::1/128"
      ]
    }
  },
  "Security": {
    "TrustedRootCaPath": "infra/certs/ca.crt"
  },
  "Keycloak": {
    "Authority": "https://localhost:8443/realms/sentinel",
    "Audience": "sentinel-api",
    "RequireHttpsMetadata": true
  },
  "Cryptography": {
    "ActiveKeyId": "default",
    "KeyRing": {
      "default": "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
    }
  },
  "FeatureFlags": {
    "Auth": {
      "DpopFlow": true
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.AspNetCore.Routing": "Debug",
      "Microsoft.AspNetCore.Hosting": "Information"
    }
  }
}
