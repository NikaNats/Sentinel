{
  "stryker-config": {
    "reporters": [
      "progress",
      "html",
      "cleartext"
    ],
    "thresholds": {
      "high": 85,
      "low": 70,
      "break": 45
    },
    "coverage-analysis": "perTest",
    "concurrency": 4,
    "ignore-mutations": [
      "string"
    ],
    "ignore-methods": [
      "Log*",
      "Write*",
      "Emit*",
      "WipeKey"
    ],
    "mutate": [
      "**/*.cs",
      "!**/*Extensions.cs",
      "!**/*Options.cs",
      "!**/GlobalUsings.cs"
    ]
  }
}
