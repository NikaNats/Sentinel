{
  "$schema": "https://json.schemastore.org/stryker-config",
  "stryker-config": {
    "project": "Sentinel.DPoP.csproj",
    "test-runner": "MTP",
    "mutation-level": "Advanced",
    "coverage-analysis": "off",
    "disable-bail": false,
    "disable-mix-mutants": false,
    "reporters": [
      "dots",
      "html",
      "cleartext",
      "markdown"
    ],
    "thresholds": {
      "high": 85,
      "low": 70,
      "break": 70
    },
    "additional-timeout": 3000,
    "ignore-methods": [
      "*Log*",
      "Console.Write*",
      "Emit*",
      "WipeKey",
      "*Exception.ctor",
      "Diagnostics*",
      "Trace*"
    ],
    "mutate": [
      "**/*.cs",
      "!**/*Extensions.cs",
      "!**/*Options.cs",
      "!**/GlobalUsings.cs",
      "!**/*.g.cs",
      "!**/*JsonContext.cs"
    ]
  }
}
